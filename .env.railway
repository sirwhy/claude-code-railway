# ─────────────────────────────────────────────────────────────────────────────
# RAILWAY ENVIRONMENT VARIABLES
# Copy these into your Railway project → Service → Variables tab.
# DATABASE_URL is injected automatically when you add a PostgreSQL plugin.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Bot username (without @)
TELEGRAM_BOT_USERNAME=your_bot_username

# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Custom Anthropic API base URL — gunakan ini untuk proxy seperti 9router
# Contoh: https://cli-proxy-api-production-d321.up.railway.app/v1
ANTHROPIC_BASE_URL=https://cli-proxy-api-production-d321.up.railway.app/v1

# PostgreSQL connection string (auto-injected by Railway PostgreSQL plugin)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── SECURITY ─────────────────────────────────────────────────────────────────

# Comma-separated Telegram user IDs allowed to use the bot
ALLOWED_USERS=123456789

# Disable security pattern validation if needed (trusted env)
DISABLE_SECURITY_PATTERNS=false

# ── WORKSPACE ────────────────────────────────────────────────────────────────

# Directory the bot can read/write. /workspace is created in the container.
APPROVED_DIRECTORY=/workspace

# ── CLAUDE SETTINGS ──────────────────────────────────────────────────────────

USE_SDK=true
CLAUDE_MAX_TURNS=10
CLAUDE_TIMEOUT_SECONDS=300
CLAUDE_MAX_COST_PER_USER=10.0
CLAUDE_MAX_COST_PER_REQUEST=5.0

# ── FEATURES ─────────────────────────────────────────────────────────────────

ENABLE_GIT_INTEGRATION=true
ENABLE_FILE_UPLOADS=true
ENABLE_QUICK_ACTIONS=true
ENABLE_IMAGE_UPLOADS=true
ENABLE_CONVERSATION_MODE=true
ENABLE_VOICE_MESSAGES=false   # set true + add MISTRAL_API_KEY or OPENAI_API_KEY to enable

# ── RATE LIMITING ─────────────────────────────────────────────────────────────

RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=60
RATE_LIMIT_BURST=20

# ── OPTIONAL ──────────────────────────────────────────────────────────────────

# Voice transcription (optional)
# VOICE_PROVIDER=mistral
# MISTRAL_API_KEY=
# OPENAI_API_KEY=

# Error tracking (optional)
# SENTRY_DSN=

# Logging
LOG_LEVEL=INFO
ENVIRONMENT=production
DEBUG=false
DEVELOPMENT_MODE=false
